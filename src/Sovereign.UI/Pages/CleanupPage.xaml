<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sovereign.UI.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Sovereign.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Cleanup &amp; hardening" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Pick a level, review what it selects, and apply. Every change is captured first so you can undo it from Restore points."
                       Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Level selector -->
        <Border Grid.Row="1" Style="{StaticResource StatCard}" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock Text="Hardening level" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <RadioButton x:Name="LiteRadio" GroupName="lvl" Tag="Lite" Checked="OnLevelChecked"
                                 ToolTipService.ToolTip="Only the most obvious, lowest-risk wins.">
                        <StackPanel>
                            <TextBlock Text="Lite" FontWeight="SemiBold" />
                            <TextBlock Text="Just the worst offenders" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NormalRadio" GroupName="lvl" Tag="Normal" IsChecked="True" Checked="OnLevelChecked"
                                 ToolTipService.ToolTip="The recommended balance of privacy and convenience.">
                        <StackPanel>
                            <TextBlock Text="Normal" FontWeight="SemiBold" />
                            <TextBlock Text="Recommended" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="ProRadio" GroupName="lvl" Tag="Pro" Checked="OnLevelChecked"
                                 ToolTipService.ToolTip="I just want a fucking Windows computer.">
                        <StackPanel>
                            <TextBlock Text="Pro" FontWeight="SemiBold" />
                            <TextBlock Text="I just want a Windows computer" Opacity="0.7" FontSize="12" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Action bar -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="ApplyButton" Grid.Column="0" Style="{ThemeResource AccentButtonStyle}" Click="OnApplySelected">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;" FontSize="14" />
                    <TextBlock x:Name="ApplyButtonText" Text="Apply selected" />
                </StackPanel>
            </Button>
            <Button x:Name="RescanButton" Grid.Column="1" Click="OnRescan">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Re-scan" />
                </StackPanel>
            </Button>
            <ProgressRing x:Name="Busy" Grid.Column="2" Width="22" Height="22" IsActive="False" VerticalAlignment="Center" />
            <TextBlock x:Name="SelectionText" Grid.Column="4" VerticalAlignment="Center" Opacity="0.7" />
        </Grid>

        <!-- Result -->
        <InfoBar x:Name="ResultBar" Grid.Row="3" IsOpen="False" IsClosable="True" />

        <!-- Policy tiles -->
        <ListView x:Name="PolicyList" Grid.Row="4"
                  SelectionMode="None"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,10" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PolicyViewModel">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />

                        <StackPanel Grid.Column="1" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                <Border CornerRadius="10" Padding="8,1" VerticalAlignment="Center"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <TextBlock Text="{x:Bind Category}" FontSize="11" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Description}" Opacity="0.75" TextWrapping="Wrap" FontSize="13" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="110">
                            <Border CornerRadius="10" Padding="10,2" HorizontalAlignment="Right"
                                    Background="{x:Bind StateBrush, Mode=OneWay}">
                                <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="12"
                                           Foreground="White" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <Ellipse Width="9" Height="9" Fill="{x:Bind RiskBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind RiskText}" FontSize="11" Opacity="0.7" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
