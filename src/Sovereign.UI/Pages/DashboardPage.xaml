<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sovereign.UI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20" MaxWidth="1100" HorizontalAlignment="Stretch">

            <StackPanel Spacing="2">
                <TextBlock Text="Sovereign" FontSize="32" FontWeight="SemiBold" />
                <TextBlock Text="Your PC, on your terms. Reversible privacy and performance controls for everyone who uses this machine."
                           Opacity="0.7" TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar x:Name="OfflineBar" IsOpen="False" IsClosable="False" Severity="Warning"
                     Title="Service offline"
                     Message="The Sovereign service is not reachable. Start it, then click Refresh." />

            <!-- Hero -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Make this PC fast &amp; private" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                        <TextBlock x:Name="ComplianceSummary" Text="Checking what's applied..." TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextOnAccentFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Center" Click="OnOpenCleanup"
                            Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE90F;" FontSize="16" />
                            <TextBlock Text="Open Cleanup" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Health cards -->
            <TextBlock Text="Service health" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="State" Opacity="0.7" FontSize="12" />
                        <TextBlock x:Name="StateText" Text="-" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Version" Opacity="0.7" FontSize="12" />
                        <TextBlock x:Name="VersionText" Text="-" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Uptime (s)" Opacity="0.7" FontSize="12" />
                        <TextBlock x:Name="UptimeText" Text="-" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Audit events" Opacity="0.7" FontSize="12" />
                        <TextBlock x:Name="EventCountText" Text="-" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Click="OnRefresh" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
