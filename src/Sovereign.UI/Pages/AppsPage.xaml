<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sovereign.UI.Pages.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Sovereign.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="AppsCvs" IsSourceGrouped="True" />
    </Page.Resources>

    <Grid Padding="32,24,32,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Apps &amp; debloat" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Store apps and classic installed programs (McAfee, OEM bloat, Office, and the rest). Recommended bloat is pre-selected; protected system apps are read-only."
                       Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Filter + actions -->
        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <RadioButton x:Name="FilterRecommended" Content="Recommended" GroupName="appfilter" IsChecked="True" Checked="OnFilterChanged" />
                <RadioButton x:Name="FilterAll" Content="All apps" GroupName="appfilter" Checked="OnFilterChanged" Margin="8,0,0,0" />
                <RadioButton x:Name="FilterSystem" Content="System" GroupName="appfilter" Checked="OnFilterChanged" Margin="8,0,0,0" />
            </StackPanel>

            <TextBox Grid.Column="1" x:Name="SearchBox" PlaceholderText="Search apps…" MaxWidth="280"
                     HorizontalAlignment="Right" VerticalAlignment="Center" TextChanged="OnSearchChanged" />

            <Button Grid.Column="2" Click="OnRescan" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Re-scan" />
                </StackPanel>
            </Button>

            <Button Grid.Column="3" x:Name="RemoveButton" Click="OnRemoveSelected" Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Center" Margin="4,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="Remove selected" />
                </StackPanel>
            </Button>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <ProgressRing x:Name="Busy" IsActive="False" Width="18" Height="18" />
            <TextBlock x:Name="SummaryText" Text="Loading installed apps…" Opacity="0.8" VerticalAlignment="Center" />
        </StackPanel>

        <InfoBar x:Name="ResultBar" Grid.Row="3" IsOpen="False" IsClosable="True" />

        <ListView x:Name="AppsList" Grid.Row="4" SelectionMode="None" Margin="0,4,0,0"
                  ShowsScrollingPlaceholders="True"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.GroupStyle>
                <GroupStyle HidesIfEmpty="True">
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="vm:AppGroup">
                            <Border Padding="0,10,0,4">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Opacity="0.75">
                                    <Run Text="{x:Bind Key}" /><Run Text="  ·  " /><Run Text="{x:Bind CountLabel}" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:AppRowViewModel">
                    <Grid ColumnSpacing="14" Opacity="{x:Bind RowOpacity, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  IsEnabled="{x:Bind CanSelect, Mode=OneWay}" MinWidth="0" VerticalAlignment="Center" />

                        <Grid Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center">
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6"
                                    Visibility="{x:Bind GlyphVisibility, Mode=OneWay}">
                                <FontIcon Glyph="&#xECAA;" FontSize="16" Opacity="0.7" />
                            </Border>
                            <Image Source="{x:Bind IconSource, Mode=OneWay}" Width="32" Height="32"
                                   Visibility="{x:Bind IconVisibility, Mode=OneWay}" />
                        </Grid>

                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind PublisherLine}" Opacity="0.5" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="{x:Bind StatusText, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />

                        <Border Grid.Column="4" CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                Background="{x:Bind BadgeBrush}">
                            <TextBlock Text="{x:Bind BadgeText}" FontSize="11" Foreground="White" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
